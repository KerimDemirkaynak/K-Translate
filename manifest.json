{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "short_name": "K-Translate",
  "description": "__MSG_extensionDescription__",
  "version": "22.1.0",
  "default_locale": "en",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup/popup.html",
    "default_title": "__MSG_popupTitle__"
  },

  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "*://translate.googleapis.com/*",
    "<all_urls>"
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "k-translate@kerim.dev",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },

  "background": {
    "scripts": ["background.js"]
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}